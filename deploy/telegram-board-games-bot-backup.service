[Unit]
Description=Back up Telegram Board Games Bot database

[Service]
Type=oneshot
User=telegrambot
Group=telegrambot
WorkingDirectory=/opt/telegram-board-games-bot
EnvironmentFile=/opt/telegram-board-games-bot/.env
ExecStart=/opt/telegram-board-games-bot/.venv/bin/python -m telegram_board_games_bot.backup backup --output backups --keep 7
